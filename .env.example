# Torn Ranked War Tracker Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════

# Host and port for the uvicorn server
HOST=127.0.0.1
PORT=8005

# ═══════════════════════════════════════════════════
# Polling / Update Intervals
# ═══════════════════════════════════════════════════

# How often the frontend polls the backend (in milliseconds)
# With a VPS, 1000ms (1 second) is ideal
FRONTEND_POLL_INTERVAL=1000

# Cache TTL for enemy faction data (in seconds)
# How long to cache Torn API responses before re-fetching
# Lower = fresher data but more API calls. 1-2s is good on VPS.
CACHE_TTL=1

# ═══════════════════════════════════════════════════
# Torn Game Configuration
# ═══════════════════════════════════════════════════

# Enemy faction IDs (comma-separated if multiple)
ENEMY_FACTION_IDS=8795

# Faction Access Control (Optional)
# If set, only members of this faction can use the tracker
# Leave blank/commented to allow anyone with a valid API key
FACTION_ID=42055

# Leadership Whitelist (Optional)
# Comma-separated list of player IDs who can access faction overview
LEADERSHIP_WHITELIST=3932427,3223361,1844909,2573771,3055230,2862329,3089481,2965729

# FFScouter API Key (Optional)
# Register your Torn API key at https://ffscouter.com/ to get stat estimates
# Uses FFScouter as primary stats source, falls back to YATA if unavailable
FFSCOUTER_API_KEY=59lORnenArL7tYYx

# ═══════════════════════════════════════════════════
# Claim Configuration
# ═══════════════════════════════════════════════════

# How long claims last before auto-expiring (in seconds)
CLAIM_EXPIRY=300

# Maximum number of targets a single user can claim at once
MAX_CLAIMS_PER_USER=1

# ═══════════════════════════════════════════════════
# Cooldown Maximums (in minutes)
# ═══════════════════════════════════════════════════

DRUG_CD_MAX=480
MED_CD_MAX=540
BOOSTER_CD_MAX=2880
